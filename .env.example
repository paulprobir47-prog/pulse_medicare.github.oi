SECRET_KEY=change-me
MYSQL_REQUIRED=true
MYSQL_HOST=your-mysql-host
MYSQL_PORT=3306
MYSQL_USER=your-mysql-user
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=pulse_medicare
MYSQL_SSL_MODE=REQUIRED

# Alternative single-URL form:
# MYSQL_URL=mysql://user:password@host:3306/pulse_medicare?ssl-mode=REQUIRED

# Optional, only if your MySQL provider requires a CA certificate file path:
# MYSQL_SSL_CA=/etc/secrets/ca.pem
